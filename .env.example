# Kopier denne fil til .env.local for lokal udvikling
# I produktion: tilføj ALLE disse i Vercel → Settings → Environment Variables

# ── Supabase ──────────────────────────────────────────
# Find i Supabase: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXX.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Resend ────────────────────────────────────────────
# API key: resend.com → API Keys (vælg "Sending access" — IKKE Full access)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX

# Afsender-adresse. Indtil dit domæne er verificeret, brug onboarding@resend.dev
# Når brandsurface.dk er verificeret: skift til f.eks. ordre@brandsurface.dk
RESEND_FROM=onboarding@resend.dev

# ── Brandsurface modtager-mail ────────────────────────
BRANDSURFACE_EMAIL=ls@brandsurface.dk

# ── Base URL (bruges i Godkend/Fortryd mail-links) ────
# Lokalt: http://localhost:3000
# Produktion: https://din-app.vercel.app
NEXT_PUBLIC_BASE_URL=https://din-app.vercel.app
