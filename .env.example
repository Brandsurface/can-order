# Copy this file to .env.local for local development.
# In production: add ALL of these in Vercel → Settings → Environment Variables.

# ── Supabase ──────────────────────────────────────────
# Find in Supabase: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXX.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Brevo (transactional email) ───────────────────────
# API key: app.brevo.com → SMTP & API → API Keys (create a v3 key)
BREVO_API_KEY=xkeysib-XXXXXXXXXXXXXXXX

# Verified sender. Add & verify the address (or the brandsurface.dk domain)
# under Brevo → Senders, Domains & Dedicated IPs before going live.
SENDER_EMAIL=ordre@brandsurface.dk
SENDER_NAME=Brand Surface

# ── Brand Surface recipient email ─────────────────────
# Fallback recipient if none is set in the admin Settings page.
BRANDSURFACE_EMAIL=ls@brandsurface.dk

# ── Admin session secret ──────────────────────────────
# Any long random string. Used to sign admin session cookies.
# Generate one with: openssl rand -hex 32
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# ── Base URL (used in the Edit/confirm email links) ───
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
